# Student Budget Manager - Environment Configuration
# Copy this file to .env and update values for your environment

# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# For SQLite (default):
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# For PostgreSQL (production):
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=budget_db
# DATABASE_USER=postgres
# DATABASE_PASSWORD=password
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# Security
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False

# Session
SESSION_COOKIE_AGE=1209600
SESSION_EXPIRE_AT_BROWSER_CLOSE=False

# Email (optional, for future notifications)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Change these for production!
# Production settings should:
# - Set DEBUG=False
# - Use a secure SECRET_KEY
# - Set ALLOWED_HOSTS to your domain
# - Enable SSL/HTTPS (SECURE_SSL_REDIRECT=True)
# - Use PostgreSQL or other production database
